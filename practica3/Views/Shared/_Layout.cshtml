<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Práctica3</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Consulta">Práctica3</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Home" asp-action="Consulta">Consulta</a>
                <a class="nav-link" asp-controller="Home" asp-action="Registro">Registro</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="p-4 mb-4 bg-light border rounded">
            <h2>Bienvenido al sistema de pagos parciales</h2>
            <p>Consulta compras y registra abonos.</p>
        </div>

        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>